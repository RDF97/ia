{
  "expo": {
    "name": "Homie",
    "slug": "clara",
    "scheme": "homie",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.homie.app"
    },
    "android": {
      "package": "com.homie.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive.png",
        "backgroundColor": "#1F4D52"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/adaptive.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#1F4D52"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive.png",
          "color": "#1F4D52"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Homie usa tus fotos para escanear tickets de compra.",
          "cameraPermission": "Homie usa la cámara para escanear tickets de compra."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "appwriteEndpoint": "https://appwrite.lademanu.es/v1",
      "appwriteProjectId": "6a552b8f0019ea6d2787",
      "appwriteDatabaseId": "homie",
      "appwriteTasksCollectionId": "tasks",
      "appwriteShoppingCollectionId": "shopping_items",
      "appwriteExpensesCollectionId": "expenses",
      "appwriteEventsCollectionId": "events",
      "appwriteProductsCollectionId": "products",
      "appwritePricesCollectionId": "price_points",
      "appwriteCategoriesCollectionId": "categories",
      "appwriteSettlementsCollectionId": "settlements",
      "appwriteInvitesCollectionId": "invites",
      "homieApkUrl": "https://github.com/RDF97/ia/releases/latest/download/homie.apk",
      "appwriteJoinFunctionId": "joinHogar",
      "appwriteScanFunctionId": "scanReceipt"
    }
  }
}
